<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="terminator.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Terminator\Terminator">
    </Installer>
    <PackageInformation
        PackageName="Terminator"
        PackageDisplayName="Terminator"
        PublisherName="CN=Terminator"
        PublisherDisplayName="Terminator"
        Version="0.1.0.0"
        PackageDescription="Terminator Description">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.terminator.desktop"
                Description="Terminator Description"
                DisplayName="Terminator"
                ExecutableName="terminator.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Terminator</DisplayName>
            <PublisherDisplayName>Terminator</PublisherDisplayName>
            <Description>Terminator Description</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="terminator.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
